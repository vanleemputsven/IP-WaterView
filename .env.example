# Copy to `.env.local` and fill in your own values (never commit `.env.local`).
#
# Supabase: Project Settings → API (URL + anon key)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Database: Project Settings → Database (connection strings / pooler + direct)
# Use the pooler URL for DATABASE_URL (Prisma) and the direct session URL for DIRECT_URL (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
