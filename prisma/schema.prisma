// AquaSense - Pool monitoring platform
// PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth & Users
// Supabase Auth manages auth.users; we sync to Profile for app-specific data
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique // Supabase auth.users.id
  email     String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices Device[]

  @@map("profiles")
}

// ---------------------------------------------------------------------------
// Pool dosing (volume + chemistry products for homeowner dosing estimates)
// ---------------------------------------------------------------------------

enum ChlorineProductKind {
  SODIUM_HYPOCHLORITE_14
  SODIUM_HYPOCHLORITE_125
  CALCIUM_HYPOCHLORITE_65
  TRICHLOR_90
  DICHLOR_56
  LITHIUM_HYPOCHLORITE_35
  CUSTOM
}

enum PhMinusKind {
  MURIATIC_31
  DRY_ACID_SODIUM_BISULFATE
  SULFURIC_38
  CUSTOM
}

enum PhPlusKind {
  SODA_ASH
  SODIUM_BICARBONATE
  CUSTOM
}

/// One row per device: pool volume and chemistry products for dose estimates (scoped to that sensor / pool).
model DevicePoolDosingSettings {
  id        String   @id @default(cuid())
  deviceId  String   @unique
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  volumeLiters Decimal @db.Decimal(14, 2)

  chlorineProductKind               ChlorineProductKind @default(SODIUM_HYPOCHLORITE_125)
  chlorineActivePercentOverride     Decimal? @db.Decimal(8, 4)

  phMinusKind                           PhMinusKind @default(MURIATIC_31)
  phMinusConcentrationPercentOverride   Decimal? @db.Decimal(8, 4)

  phPlusKind                       PhPlusKind @default(SODA_ASH)
  phPlusPurityPercentOverride      Decimal? @db.Decimal(8, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("device_pool_dosing_settings")
}

// ---------------------------------------------------------------------------
// IoT Devices
// ---------------------------------------------------------------------------

model Device {
  id          String   @id @default(cuid())
  name        String
  apiKeyHash  String   // bcrypt or similar; never store plain key
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  measurements Measurement[]

  deviceThresholds DeviceThreshold[]

  devicePoolDosingSettings DevicePoolDosingSettings?

  @@unique([profileId, name])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// Measurements
// ---------------------------------------------------------------------------

model Measurement {
  id         String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())

  // Pool metrics (nullable for future extensibility)
  temperatureCelsius Decimal? @db.Decimal(4, 2)
  ph                 Decimal? @db.Decimal(3, 2)
  chlorinePpm        Decimal? @db.Decimal(4, 2)

  createdAt DateTime @default(now())

  @@index([deviceId, timestamp])
  @@index([timestamp])
  @@map("measurements")
}

// ---------------------------------------------------------------------------
// System / Audit Logs
// ---------------------------------------------------------------------------

model SystemLog {
  id        String   @id @default(cuid())
  actorType String   // "user" | "device" | "system"
  actorId   String?  // profileId or deviceId
  action    String
  resource  String?  // e.g. "measurement", "device", "settings"
  metadata  Json?    // flexible payload
  createdAt DateTime @default(now())

  @@index([actorType, actorId])
  @@index([createdAt])
  @@index([action])
  @@map("system_logs")
}

// ---------------------------------------------------------------------------
// Settings / Thresholds
// ---------------------------------------------------------------------------

/// Platform defaults: copied to each new device at registration (admin template).
model Threshold {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "temperature_min", "ph_max", "chlorine_min"
  value     Decimal  @db.Decimal(10, 4)
  unit      String?  // e.g. "celsius", "ppm"
  updatedAt DateTime @updatedAt

  @@map("thresholds")
}

/// Per-device limits used for alerts and dashboards (may differ per sensor).
model DeviceThreshold {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  key       String
  value     Decimal  @db.Decimal(10, 4)
  unit      String?
  updatedAt DateTime @updatedAt

  @@unique([deviceId, key])
  @@index([deviceId])
  @@map("device_thresholds")
}
